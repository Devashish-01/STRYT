{
  "name": "stryt",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "audit": "playwright test",
    "audit:report": "playwright show-report",
    "audit:login": "node -e \"require('fs').rmSync('.auth/session.json',{force:true})\" && playwright test --project=setup",
    "audit:mobile": "playwright test --project=mobile",
    "audit:desktop": "playwright test --project=desktop"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@types/leaflet": "^1.9.21",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "html5-qrcode": "^2.3.8",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.456.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "pg": "^8.21.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
