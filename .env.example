# Copy to .env to override. Defaults run fully on mock data, no backend needed.

# Backend base URL (versioned). Used by the legacy apiRequest fallback when
# VITE_USE_MOCKS=false (most paths now use Supabase directly).
VITE_API_URL=https://api.stryt.app/v1

# ⚠️ PRODUCTION: this MUST be "false" in your host (e.g. Vercel) env.
# When "true", the app runs in a half-mocked state — OAuth login, personal-data
# hydration (bookmarks/follows/lists), and photo uploads do NOT work against the
# real backend. Local dev can keep it "true" to work offline on mock data.
VITE_USE_MOCKS=true

# --- Supabase (only the PUBLIC anon key — never the service_role key) ---
# Find these in Supabase: Project Settings -> API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Mapbox token for the live map (used by the tracking page + map view).
VITE_MAPBOX_TOKEN=

# Excel/Google Sheets link for reporting bugs
VITE_BUG_REPORT_EXCEL_URL=
VITE_BUG_REPORT_SCRIPT_URL=

# Push notifications — leave blank until VAPID keys are generated.
# Generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=

# ============================================================
# SERVER-SIDE SECRETS — do NOT put these in VITE_* vars (they'd ship to the
# browser). Set them on the Edge Functions with `supabase secrets set NAME=...`:
#   GEMINI_API_KEY        -> ai-assist (request categorize)
#   VAPID_PUBLIC_KEY      -> send-push
#   VAPID_PRIVATE_KEY     -> send-push
#   VAPID_SUBJECT         -> send-push (e.g. mailto:team@stryt.app)
#   RAZORPAY_KEY_ID       -> (when online payments are enabled)
#   RAZORPAY_KEY_SECRET   -> (when online payments are enabled)
# A Supabase management/access token must also stay out of this client env file.
# ===============================================================

# --- Firebase Configuration ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

