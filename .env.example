# Copy to .env to override. Defaults run fully on mock data, no backend needed.

# Backend base URL (versioned). Used by the legacy apiRequest fallback when
# VITE_USE_MOCKS=false (most paths now use Supabase directly).
VITE_API_URL=https://api.naya.app/v1

# Flip to "false" to route services to the real backend (Supabase).
# When "true", the app runs entirely on in-memory mock data.
VITE_USE_MOCKS=true

# --- Supabase (only the PUBLIC anon key — never the service_role key) ---
# Find these in Supabase: Project Settings -> API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Mapbox token for the live map (optional until the real map is wired).
VITE_MAPBOX_TOKEN=
